# React OAS Integration Project - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ==================================================
# FRONTEND CONFIGURATION
# ==================================================
# CRA (react-scripts): dùng REACT_APP_*
# Lưu ý: đừng đặt PORT=3001 ở file này nếu chạy `npm start` — CRA đọc PORT, sẽ đụng backend (3001).
REACT_APP_API_URL=http://localhost:3001
REACT_APP_AI_SERVICE_URL=http://localhost:8000
# Alias (nếu dự án cũ chỉ có biến này):
# REACT_APP_AI_URL=http://localhost:8000
# production: đặt false để không fallback mock khi Sheets API lỗi
REACT_APP_ALLOW_SHEETS_MOCK=true

VITE_API_BASE_URL=http://localhost:3001/api
VITE_AI_SERVICE_URL=http://localhost:8000
VITE_ENVIRONMENT=development

# ==================================================
# BACKEND CONFIGURATION
# ==================================================
NODE_ENV=development
PORT=3001
JWT_SECRET=your_jwt_secret_key_here

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=react_oas_integration
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ==================================================
# AUTOMATION SYSTEM CONFIGURATION
# ==================================================
# Ports: AI Service 8000 | Automation 8001 — chạy song song được
REACT_APP_AUTOMATION_API_URL=http://localhost:8001

# Google Sheets & Drive API
# Xem docs/GOOGLE_CREDENTIALS_SETUP.md
GOOGLE_APPLICATION_CREDENTIALS=./config/google-credentials.json
# Backend (backend/src/server.js) đọc — ưu tiên:
GOOGLE_SHEETS_SPREADSHEET_ID=18B1PIhCDmBWyHZytvOcfj_1QbYBwczLf1x1Qbu0E5As
REACT_APP_GOOGLE_SHEETS_SPREADSHEET_ID=18B1PIhCDmBWyHZytvOcfj_1QbYBwczLf1x1Qbu0E5As
# Frontend googleConfig.js + vài script (đồng bộ cùng ID ở trên):
REACT_APP_GOOGLE_SHEET_ID=18B1PIhCDmBWyHZytvOcfj_1QbYBwczLf1x1Qbu0E5As
# Legacy / health-check — nên trùng ID với GOOGLE_SHEETS_SPREADSHEET_ID
GOOGLE_SHEETS_ID=18B1PIhCDmBWyHZytvOcfj_1QbYBwczLf1x1Qbu0E5As
# Drive folder: https://drive.google.com/drive/folders/1OpCHA1Qnf3AHYZqzRjzeiMxODoAeV4_V
GOOGLE_DRIVE_FOLDER_ID=1OpCHA1Qnf3AHYZqzRjzeiMxODoAeV4_V

# Email Configuration
SMTP_HOST=warehouse@mia.vn
SMTP_PORT=587
SMTP_USER=warehouse@mia.vn
SMTP_PASSWORD==warehouse@mia.vn
EMAIL_FROM_NAME=React OAS Integration System

# Report Configuration
REPORT_RECIPIENTS=admin@yourcompany.com,manager@yourcompany.com
REPORT_SCHEDULE_HOUR=9
REPORT_SCHEDULE_MINUTE=0

# OpenAPI Specification URLs
OAS_SPEC_URL=https://api.yourservice.com/openapi.json
OAS_BACKUP_URL=https://backup.yourservice.com/openapi.json

# ==================================================
# OPTIONAL INTEGRATIONS
# ==================================================

# Slack Integration (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#notifications

# Microsoft Teams Integration (optional)
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR/TEAMS/WEBHOOK

# AWS Integration (optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-backup-bucket

# Azure Integration (optional)
AZURE_STORAGE_ACCOUNT=your_storage_account
AZURE_STORAGE_KEY=your_storage_key
AZURE_CONTAINER_NAME=oas-backups

# ==================================================
# DEVELOPMENT & TESTING
# ==================================================
LOG_LEVEL=info
DEBUG_MODE=false
TEST_MODE=false
MOCK_EXTERNAL_APIS=false

# Performance Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Rate Limiting
API_RATE_LIMIT_PER_MINUTE=100
API_RATE_LIMIT_PER_HOUR=1000
