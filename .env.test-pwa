# Env cho test PWA local (test-service-worker.sh)
# Dùng: cp .env.test-pwa .env.production.local && npm run build
# Rồi: ./test-service-worker.sh
# Và chạy Backend: cd backend && npm start

# API → Backend (3001)
REACT_APP_API_BASE_URL=http://localhost:3001/api
REACT_APP_API_URL=http://localhost:3001

# WebSocket → Backend ws-server (3002) hoặc dùng Backend Socket.IO
# Lưu ý: WebSocketClient dùng raw WS; Backend dùng Socket.IO. Cần ws-server chạy riêng.
REACT_APP_WS_URL=ws://localhost:3002/ws

# AI (optional)
REACT_APP_AI_SERVICE_URL=http://localhost:8001
