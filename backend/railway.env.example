# Railway — biến môi trường mẫu (copy ý nghĩa lên Dashboard, không commit file có secret)
# Backend: https://react-oas-integration-backend-production.up.railway.app

NODE_ENV=production

# Railway injects PORT (e.g. 8080)
# PORT=8080

# Google (trùng spreadsheet frontend nếu cùng hệ thống)
GOOGLE_SHEETS_SPREADSHEET_ID=
# hoặc
REACT_APP_GOOGLE_SHEETS_SPREADSHEET_ID=

GOOGLE_DRIVE_FOLDER_ID=
REACT_APP_GOOGLE_DRIVE_FOLDER_ID=

# Đường dẫn file JSON trong image hoặc biến JSON — tuỳ cách deploy
# GOOGLE_APPLICATION_CREDENTIALS=/app/config/google-credentials.json
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=config/google-credentials.json

JWT_SECRET=replace_with_long_random_string
SESSION_SECRET=replace_with_long_random_string

# CORS nếu sau này siết origin
# ALLOWED_ORIGINS=https://react-oas-integration-v4-0.vercel.app

# Email / Telegram (nếu backend gửi)
# SMTP_HOST=
# SMTP_PORT=587
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
