{
  "name": "react-oas-integration",
  "version": "3.0.0",
  "description": "React OAS Integration v3.0 - AI-Powered Platform",
  "main": "index.js",
  "packageManager": "npm@10.0.0",
  "scripts": {
    "build": "GENERATE_SOURCEMAP=false react-scripts build",
    "analyze:bundle": "npm run webpack-bundle-analyzer",
    "build:wasm": "cargo build --target wasm32-unknown-unknown --release",
    "test:rust": "cargo test",
    "check:rust": "cargo check",
    "build:rust": "cargo build --release",
    "analyze:rust": "cargo clippy && cargo audit",
    "start": "react-scripts start",
    "prepare": "husky",
    "build:prod": "GENERATE_SOURCEMAP=false react-scripts build",
    "build:maps": "GENERATE_SOURCEMAP=true react-scripts build",
    "analyze:maps": "npm run build:maps && node scripts/source-map-explore-chunk.js",
    "build:analyze": "GENERATE_SOURCEMAP=true react-scripts build && npm run analyze",
    "test": "react-scripts test",
    "test:complete": "npm run test:ci && npm run test:scripts",
    "test:coverage": "CI=true react-scripts test --coverage --watchAll=false",
    "test:ci": "CI=true react-scripts test --watchAll=false",
    "perf:check": "node scripts/performance-budget.js",
    "eject": "react-scripts eject",
    "dev": "concurrently \"npm run start\" \"npm run backend\" \"npm run ai-service\"",
    "fix:git-push": "git add . && git commit -m 'fix: git push' && git push",
    "cleanup:duplicates": "bash scripts/cleanup-duplicates.sh",
    "backend": "cd backend && npm start",
    "ai-service": "cd ai-service && python -m uvicorn main_simple:app --host 0.0.0.0 --port 8000 --reload",
    "vercel-build": "npm run build",
    "analyze": "node scripts/perf-bundle-analyzer.js",
    "analyze-deps": "node scripts/analyze-bundle-deps.js",
    "test:frontend": "react-scripts test",
    "test:backend": "jest",
    "test:integration": "npm run test:scripts",
    "test:scripts": "node scripts/test-all.js",
    "analyze:sourcemap": "node scripts/generate-bundle-stats.js",
    "test:e2e": "jest end-to-end-tests",
    "test:all": "concurrently \"npm run test:frontend\" \"npm run test:backend\" \"npm run test:integration\" \"npm run test:e2e\"",
    "test:google-sheets": "node scripts/tests/test_google_sheets.js",
    "test:google": "node scripts/testGoogleConnection.cjs",
    "test:email": "node scripts/testEmailService.js",
    "test:telegram": "node scripts/testTelegramConnection.js",
    "test:api": "node scripts/test-api-endpoints.js",
    "test:automation": "node scripts/test-automation-system.js",
    "test:websocket": "node scripts/test-websocket.js",
    "webpack-bundle-analyzer": "node scripts/perf-bundle-analyzer.js",
    "webpack-bundle-analyzer-production": "node scripts/perf-bundle-analyzer.js",
    "webpack-bundle-analyzer-deps": "node scripts/analyze-bundle-deps.js",
    "lint": "eslint src --ext .js,.jsx",
    "lint:check": "eslint src --ext .js,.jsx --max-warnings 0",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "type:check": "tsc --noEmit",
    "type:watch": "tsc --noEmit --watch",
    "validate": "npm run lint:check && npm run format:check && npm run type:check && npm run test:ci",
    "validate:full": "npm run validate && npm run build:prod",
    "pre-commit": "lint-staged",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css,md}\"",
    "prettier": "npm run format",
    "prettier:check": "npm run format:check",
    "serve:build": "npx serve -s build",
    "serve:deployed": "npx serve -s ~/Sites/mia-vn-integration",
    "fix:ports": "lsof -i :3000 -i :3001 -i :8000 2>/dev/null | grep LISTEN | awk '{print $2}' | xargs kill -9 2>/dev/null || true",
    "kill:port": "lsof -i :$npm_config_port | grep LISTEN | awk '{print $2}' | xargs kill -9",
    "check:ports": "lsof -i :3000 -i :3001 -i :8000 | grep LISTEN",
    "check:backend": "curl -s http://localhost:3001/health || echo 'Backend not running'",
    "health-check": "node scripts/health-check.js",
    "health:full": "bash scripts/utils/comprehensive-health-check.sh",
    "health:quick": "bash -c 'curl -fsS http://localhost:3000 >/dev/null && curl -fsS http://localhost:3001/health >/dev/null && { curl -fsS http://localhost:8000/health >/dev/null && echo \"✅ Core + AI (8000)\" || { curl -fsS http://localhost:8001/health >/dev/null && echo \"✅ Core + Automation (8001)\" || echo \"✅ Core OK (AI 8000 & Automation 8001 optional)\"; }; } || (echo \"❌ Core down\" && exit 1)'",
    "verify:setup": "bash scripts/verify-setup.sh",
    "docs:generate": "node scripts/utils/generate-complete-docs.js",
    "docs:watch": "bash scripts/utils/auto-update-docs.sh true",
    "scripts:guard-wrappers": "bash scripts/utils/check-root-shell-wrappers.sh",
    "bundle:stats": "node scripts/generate-bundle-stats.js",
    "explore:chunk": "node scripts/source-map-explore-chunk.js",
    "check:tools": "npm run tools:check",
    "deploy:prep": "npm run fix:ports && npm run format && npm run lint:fix && npm run build:prod && npm run validate:full && npm run verify:setup",
    "quick-start": "npm run fix:ports && npm run format && npm run lint:fix && npm run build:prod && npm run validate:full && npm run verify:setup",
    "build:stats": "npm run bundle:stats",
    "build:analyze:full": "npm run build:analyze && npm run analyze:sourcemap",
    "build:analyze:auto": "npm run build:analyze && npm run optimize:suggestions",
    "build:analyze:bundle": "npm run build:analyze && npm run optimize:bundle",
    "build:analyze:suggestions": "npm run build:analyze && npm run optimize:suggestions",
    "build:analyze:optimize": "npm run build:analyze && npm run optimize:optimize",
    "build:analyze:optimize:full": "npm run build:analyze && npm run optimize:optimize:full",
    "build:analyze:optimize:auto": "npm run build:analyze && npm run optimize:optimize:auto",
    "optimize:post-build": "node scripts/optimize-bundle.js",
    "stop": "npm run fix:ports",
    "perf:budget": "node scripts/performance-budget.js",
    "analyze:deps": "node scripts/analyze-bundle-deps.js",
    "start:ai-service": "npm run ai-service",
    "cargo:check": "cargo --version || echo 'Cargo not found'",
    "optimize:optimize:auto": "npm run build:analyze && npm run optimize:optimize:auto",
    "cargo:info": "node scripts/cargo-info.js",
    "cargo:optimize": "node scripts/cargo-optimize.js",
    "tools:check": "node scripts/check-tools.js",
    "analyze:all": "npm run perf:bundle && npm run perf:deps && npm run perf:size && npm run cargo:info",
    "analyze:full": "npm run analyze:all && npm run analyze:sourcemap",
    "analyze:auto": "npm run analyze:all && npm run optimize:suggestions",
    "optimize:bundle": "node scripts/optimize-bundle.js",
    "optimize:suggestions": "node scripts/optimize-bundle.js",
    "build:optimized": "node scripts/build-optimize.js",
    "perf:deps": "node scripts/analyze-bundle-deps.js",
    "perf:size": "node scripts/performance-budget.js",
    "perf:depcheck": "npx depcheck",
    "update:dependencies": "npm update",
    "perf:explore": "node scripts/generate-bundle-stats.js",
    "perf:bundle": "node scripts/perf-bundle-analyzer.js",
    "perf:lighthouse": "node scripts/performance-lighthouse.js",
    "deploy:vercel": "vercel --prod",
    "deploy:build": "npm run build:prod",
    "deploy:serve": "npx serve -s build -l 3000"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@reduxjs/toolkit": "^2.11.2",
    "antd": "^5.29.3",
    "axios": "^1.12.2",
    "browserify-zlib": "^0.2.0",
    "chalk": "^5.6.2",
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
