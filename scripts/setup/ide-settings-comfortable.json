{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "cursor.ai.enabled": true,
  "cursor.ai.autoComplete": true,
  "editor.fontFamily": "SF Pro Text, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
  "editor.fontSize": 13,
  "editor.lineHeight": 22,
  "editor.letterSpacing": 0.6,
  "editor.fontLigatures": true,
  "editor.fontWeight": "250",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.cursorBlinking": "smooth",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 2,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.guides.bracketPairs": "active",
  "editor.bracketPairColorization.enabled": true,
  "editor.rulers": [100, 120],
  "workbench.colorTheme": "Default Dark+",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.fontAliasing": "antialiased",
  "window.zoomLevel": 0,
  "workbench.colorCustomizations": {
    "editor.foreground": "#EAEAEA",
    "editorCursor.foreground": "#FFCC00",
    "editorLineNumber.foreground": "#888888",
    "editor.selectionBackground": "#264F78",
    "editor.inactiveSelectionBackground": "#3A3D41A6"
  },
  "editor.tokenColorCustomizations": {
    "comments": "#6A9955",
    "keywords": "#C586C0",
    "strings": "#CE9178",
    "functions": "#4EC9B0",
    "variables": "#9CDCFE"
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.venv": true,
    "**/venv": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/.vercel": true,
    "**/lighthouse-reports": true,
    "**/*.log": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/venv": true,
    "**/lighthouse-reports": true,
    "**/backup_markdown": true
  },
  "python.analysis.extraPaths": [
    "./automation",
    "./ai-service",
    "./one_automation_system"
  ],
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.fontFamily": "SF Mono, Menlo, monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontWeight": "250",
  "terminal.integrated.lineHeight": 1.3,
  "terminal.integrated.letterSpacing": 0.6,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/__pycache__/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": true,
    "cSpell.enabled": false
  }
}
